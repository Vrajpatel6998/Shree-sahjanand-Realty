# Port on which the Node.js API server will run
PORT=5000

# PostgreSQL database connection string
# Replace db_user, db_password, localhost, and database_name with your production VPS values
DATABASE_URL="postgresql://db_user:db_password@localhost:5432/shree_sahjanand_realty?schema=public"

# Secure random strings for JWT tokens
# Generate strong secrets (e.g. using: openssl rand -base64 32)
JWT_SECRET="replace-with-a-very-long-secure-random-secret-key-here"
JWT_REFRESH_SECRET="replace-with-another-very-long-secure-random-secret-key-here"

# Allowed origins for CORS (separate multiple origins with a comma)
# Include your production domains
ALLOWED_ORIGINS="https://shreesahjanandrealty.com,https://www.shreesahjanandrealty.com"

# Uploads directory name (relative to the server directory or an absolute path)
UPLOADS_DIR="uploads"
